# Conexión a Postgres (Supabase). Copia este archivo a .env y reemplaza el placeholder.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# En Supabase: Project Settings -> Database -> Connection string (modo "URI").
# Usa el pooler (puerto 6543) para cargas batch, o el directo (5432) para DDL.
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres

# (Opcional) User-Agent para el scraping de INFOBRAS / Contraloría.
VIGIA_USER_AGENT=Vigia-Hackathon/1.0 (+https://github.com/dsc-pucp/vigia)
